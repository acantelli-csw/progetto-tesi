# ============================================================================
# ESEMPIO DI UTILIZZO COMPLETO
# ============================================================================

def run_full_evaluation(testset_file: str):
    """
    Esegue valutazione completa multi-livello.
    """
    # Carica testset
    with open(testset_file, 'r', encoding='utf-8') as f:
        data = json.load(f)
        testset = data.get('questions', data)  # Supporta entrambi i formati
    
    # Inizializza evaluator
    evaluator = MultiLevelEvaluator(testset)
    
    # Valutazione completa
    print("\n🚀 Avvio valutazione multi-livello...")
    
    # LIVELLO 1: Retrieval
    retrieval_results = evaluator.evaluate_retrieval(k_values=[3, 5, 10])
    
    # LIVELLO 2: Relevance
    relevance_results = evaluator.evaluate_relevance(use_ground_truth=True)
    
    # LIVELLO 3 & 4: Richiedono risposte generate
    # (Da eseguire dopo aver generato risposte con il tuo LLM)
    
    # Confronto per tier
    tier_comparison = evaluator.compare_by_tier()
    
    # Genera report finale
    evaluator.generate_full_report("evaluation_report_full.json")
    
    return evaluator


if __name__ == "__main__":
    # Esempio
    evaluator = run_full_evaluation("testset_ibrido_stratificato.json")